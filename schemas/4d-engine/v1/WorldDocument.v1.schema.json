{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4d-engine.local/schemas/WorldDocument.v1.schema.json",
  "title": "WorldDocument",
  "description": "4D Engine v1 World Format — declared. Runtime loaders not claimed. Canonical copy also under docs/4d-engine/v1/schemas/.",
  "type": "object",
  "required": ["schemaVersion", "id", "entities"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "units": { "type": "string", "default": "meters" },
    "materials": {
      "type": "array",
      "items": { "$ref": "#/$defs/Material" }
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Entity" }
    },
    "defaultObservation": { "$ref": "#/$defs/ObservationHint" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Vec4": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "Rotate4D": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "xy": { "type": "number" },
        "xz": { "type": "number" },
        "xw": { "type": "number" },
        "yz": { "type": "number" },
        "yw": { "type": "number" },
        "zw": { "type": "number" }
      }
    },
    "Transform4D": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "translate": { "$ref": "#/$defs/Vec4" },
        "rotate": { "$ref": "#/$defs/Rotate4D" },
        "scale": { "$ref": "#/$defs/Vec4" }
      }
    },
    "Geometry": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["surface", "meshRef", "sdfRef", "empty"]
        },
        "surfaceId": { "type": "string" },
        "uri": { "type": "string" },
        "resolution": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "surface" } },
            "required": ["kind"]
          },
          "then": { "required": ["surfaceId"] }
        }
      ]
    },
    "Material": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "color": { "type": "string", "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "wireframe": { "type": "boolean" }
      }
    },
    "Entity": {
      "type": "object",
      "required": ["id", "geometry"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "transform4d": { "$ref": "#/$defs/Transform4D" },
        "geometry": { "$ref": "#/$defs/Geometry" },
        "materialId": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "userData": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ObservationHint": {
      "type": "object",
      "required": ["modeId"],
      "additionalProperties": false,
      "properties": {
        "modeId": { "type": "string", "minLength": 1 },
        "params": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    }
  }
}
