{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4dce.local/schemas/World.schema.json",
  "title": "GovernedWorld",
  "type": "object",
  "required": ["id", "name", "constitution", "entities"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "constitution": { "type": "string" },
    "contracts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "uri": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "components"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "parent": { "type": ["string", "null"] },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "type": "string" },
                "config": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "timelines": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
