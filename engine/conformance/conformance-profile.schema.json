{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConstitutionalConformanceProfile",
  "description": "Engine-agnostic conformance requirements. Every governed runtime must satisfy all checks to be considered constitutionally compliant.",
  "type": "object",
  "required": ["version", "checks"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/definitions/ConformanceCheck" }
    }
  },
  "definitions": {
    "ConformanceCheck": {
      "type": "object",
      "required": ["id", "domain", "description", "severity"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique check id, e.g. 'provenance.frame-fields'"
        },
        "domain": {
          "type": "string",
          "enum": [
            "provenance",
            "replay",
            "binding",
            "timeline",
            "evidence",
            "ckl"
          ]
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium"]
        }
      }
    }
  }
}
