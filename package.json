{
  "name": "@sovereignx/ciems-engine",
  "version": "1.0.0",
  "description": "Constitutional Engine (4DCE) — browser host, CSSV ledger, conformance profile",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "init:cssv": "node scripts/init-cssv-ledger.mjs",
    "test": "node scripts/test-all.mjs",
    "test:conformance": "node scripts/test-conformance.mjs",
    "test:cql": "node scripts/test-cql.mjs",
    "test:ckl": "node scripts/test-ascension-ckl.mjs",
    "test:4d-renderer": "node scripts/test-4d-renderer.mjs",
    "test:solid-play": "node scripts/test-host-solid-play.mjs",
    "export:surfaces": "node scripts/export-surface-meshes.mjs",
    "render:4d": "node 4d-renderer/src/cli.js render",
    "render:hcl-baseline": "node scripts/render-hyper-caustic-baseline.mjs --write-hashes",
    "test:bvh4d-gpu": "node scripts/test-bvh4d-gpu.mjs",
    "test:inspector4d": "node scripts/test-inspector4d.mjs",
    "inspector:ws": "node scripts/inspector-ws-server.mjs",
    "cssv:server": "node cssv/server.js",
    "serve": "node scripts/serve-static.mjs",
    "start": "node scripts/start-dev.mjs",
    "examples:gallery": "node examples/gallery/generate.mjs",
    "examples:bench": "node examples/benchmarks/bench-render.mjs",
    "test:examples": "node scripts/test-examples-smoke.mjs",
    "link:mrs-shim": "node scripts/link-mrs-shim.mjs",
    "postinstall": "node scripts/link-mrs-shim.mjs"
  },
  "dependencies": {
    "4d-renderer": "file:./4d-renderer",
    "@mrs/renderer-core": "file:./mrs/packages/renderer-core"
  }
}
