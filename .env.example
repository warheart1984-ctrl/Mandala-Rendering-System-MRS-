# MRS / 4DRS — environment placeholders (no secrets)

Copy to `.env` at the repo root (or export in your shell). `.env` is gitignored.

# --- Backblaze B2 S3-Compatible API (declared / operator-configured) ---
# Do NOT use the master application key with the S3-Compatible API.
# Create a non-master application key scoped to your bucket.
# Docs: docs/ops/BACKBLAZE_B2_S3.md

B2_KEY_ID=0000000000000000000000000
B2_APPLICATION_KEY=REPLACE_WITH_APPLICATION_KEY
# Genblaze-s3 also reads B2_APP_KEY — mrs/apps/genblaze-media dual-exports both names.
# B2_APP_KEY=
B2_BUCKET=your-mrs-assets-bucket
B2_REGION=us-west-004
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# Optional: force path-style URLs (default true in @mrs/storage-b2)
# B2_FORCE_PATH_STYLE=true

# Optional AWS SDK / CLI aliases (used if B2_KEY_ID / B2_APPLICATION_KEY unset)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-004

# --- Genblaze concept media (mrs/apps/genblaze-media) ---
# Free NIM key: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-...
# GENBLAZE_IMAGE_MODEL=black-forest-labs/flux.1-schnell
# NVIDIA_EMBED_MODEL=nvidia/nv-embedcode-7b-v1
# NVIDIA_EMBED_URL=https://integrate.api.nvidia.com/v1/embeddings
# GENBLAZE_STORAGE_PREFIX=genblaze-media
# GENBLAZE_DRY_RUN=1
