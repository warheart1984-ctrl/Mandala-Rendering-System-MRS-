{
  "name": "4d-renderer",
  "version": "1.0.0",
  "description": "Compatibility shim → @mrs/renderer-core. Re-exports only; no junction required.",
  "type": "module",
  "main": "./index.js",
  "types": "./../mrs/packages/renderer-core/types.d.ts",
  "exports": {
    ".": "./index.js",
    "./surfaces": "./surfaces.js",
    "./math": "./math.js",
    "./render/canvas": "./render-canvas.js",
    "./inspector": "./inspector.js",
    "./live-link": "./live-link.js",
    "./rt4d": "./rt4d.js",
    "./rt4d/math": "./rt4d-math.js",
    "./rt4d/geometry": "./rt4d-geometry.js",
    "./rt4d/material": "./rt4d-material.js",
    "./rt4d/integrator": "./rt4d-integrator.js",
    "./rt4d/accel": "./rt4d-accel.js",
    "./rt4d/output": "./rt4d-output.js",
    "./rt4d/scene": "./rt4d-scene.js",
    "./pipeline/ExportManager": "./ExportManager.js"
  },
  "bin": {
    "4d-render": "../mrs/packages/renderer-core/src/cli.js"
  },
  "scripts": {
    "render": "node ../mrs/packages/renderer-core/src/cli.js render",
    "list": "node ../mrs/packages/renderer-core/src/cli.js list",
    "test": "node ../mrs/packages/renderer-core/src/cli.js render --surface tesseract --single --width 320 --height 240 --output output/test",
    "test:frames": "node ../mrs/packages/renderer-core/src/cli.js render --surface clifford-torus --frames 8 --fps 8 --width 320 --height 240 --mode wireframe --resolution 16 --output output/test"
  },
  "dependencies": {
    "@mrs/renderer-core": "file:../mrs/packages/renderer-core"
  }
}
