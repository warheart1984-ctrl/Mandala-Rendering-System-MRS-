{
  "name": "4d-renderer",
  "version": "1.0.0",
  "description": "4DRS surface renderer + RT4D (Ray Tracer for Four Dimensions) path engine",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./rt4d": "./src/render/rt4d/index.js",
    "./rt4d/math": "./src/render/rt4d/math/index.js",
    "./rt4d/geometry": "./src/render/rt4d/geometry/index.js",
    "./rt4d/material": "./src/render/rt4d/material/index.js",
    "./rt4d/integrator": "./src/render/rt4d/integrator/index.js",
    "./rt4d/accel": "./src/render/rt4d/accel/index.js",
    "./rt4d/output": "./src/render/rt4d/output/index.js",
    "./rt4d/scene": "./src/render/rt4d/scene/index.js",
    "./math/*": "./src/math/*",
    "./surfaces/*": "./src/surfaces/*",
    "./render/*": "./src/render/*",
    "./pipeline/*": "./src/pipeline/*"
  },
  "bin": {
    "4d-render": "src/cli.js"
  },
  "scripts": {
    "render": "node src/cli.js render",
    "list": "node src/cli.js list",
    "test": "node src/cli.js render --surface tesseract --single --width 320 --height 240 --output output/test",
    "test:frames": "node src/cli.js render --surface clifford-torus --frames 8 --fps 8 --width 320 --height 240 --mode wireframe --resolution 16 --output output/test"
  },
  "dependencies": {
    "canvas": "^3.1.0",
    "commander": "^13.1.0",
    "ws": "^8.21.1"
  }
}
