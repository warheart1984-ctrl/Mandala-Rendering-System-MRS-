{
  "version": "1.0",
  "scene": {
    "background": "#0e1216",
    "sdf": {
      "type": "boolean",
      "op": "smoothUnion",
      "k": 0.2,
      "children": [
        { "type": "primitive", "shape": "hypertorus", "params": { "R": 1.5, "r": 0.4 }, "transform": {} },
        { "type": "primitive", "shape": "hypersphere", "params": { "radius": 0.8 }, "transform": { "translate": { "x": 0, "y": 0, "z": 0, "w": 1.2 } } }
      ]
    }
  },
  "camera": {
    "hyperplane": { "normal": { "x": 0, "y": 0, "z": 0, "w": 1 }, "offset": 0 },
    "projection": "hybrid",
    "d3": 4.0,
    "d4": 4.0,
    "scale": 80,
    "path": [
      { "t": 0.0, "hyperplaneOffset": -0.5, "rotation": { "xw": 0, "yz": 0 } },
      { "t": 1.0, "hyperplaneOffset": 0.5, "rotation": { "xw": 3.14, "yz": 2.0 } }
    ]
  },
  "render": {
    "width": 1920,
    "height": 1080,
    "frames": 180,
    "fps": 30,
    "maxSteps": 128,
    "epsilon": 0.001,
    "maxDistance": 100,
    "mode": "gpu",
    "output": "output/scenes/hypertorus-sphere"
  },
  "lighting": {
    "enabled": false
  }
}