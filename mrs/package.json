{
  "name": "mrs",
  "version": "0.1.0",
  "private": true,
  "description": "MRS monorepo — renderer-core, scene-schema, renderer-web, ChatGPT App",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter @mrs/chatgpt-app-web build",
    "build:web": "pnpm --filter @mrs/chatgpt-app-web build",
    "start:server": "pnpm --filter @mrs/chatgpt-app-server start",
    "test:renderer": "pnpm --filter @mrs/renderer-core test",
    "dev:server": "pnpm --filter @mrs/chatgpt-app-server start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild"
    ]
  }
}
