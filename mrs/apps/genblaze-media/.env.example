# Copy values from repo-root `.env` or set here for local overrides.
# Never commit real secrets.

NVIDIA_API_KEY=
# Optional aliases (app dual-exports from NVIDIA_API_KEY when set):
# NGC_API_KEY=
# NVIDIA_NIM_API_KEY=
B2_KEY_ID=
# MRS uses B2_APPLICATION_KEY; Genblaze-s3 reads B2_APP_KEY — set either (app dual-exports).
B2_APPLICATION_KEY=
# B2_APP_KEY=
B2_BUCKET=Mandala-Rendering-System
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
GENBLAZE_IMAGE_MODEL=black-forest-labs/flux.1-schnell
GENBLAZE_STORAGE_PREFIX=genblaze-media
# FLUX cold-start: long read + NVCF long-poll window (then 202→poll)
# GENBLAZE_HTTP_TIMEOUT=600
# GENBLAZE_NVCF_TIMEOUT=600
# GENBLAZE_PIPELINE_TIMEOUT=720
# GENBLAZE_NVCF_POLL_SECONDS=90
# GENBLAZE_DRY_RUN=1   # unit tests / offline only — not for live Devpost demos
