# MRS monorepo — environment placeholders (no secrets)
# Prefer repo-root `.env` for B2; this file documents the same keys for mrs/ operators.

# Backblaze B2 S3-Compatible API — declared / operator-configured
# See ../docs/ops/BACKBLAZE_B2_S3.md and ../.env.example
# Do NOT use the master application key.

B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
B2_REGION=
B2_ENDPOINT=
# B2_FORCE_PATH_STYLE=true
